# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Google Drive ===
# Path to your Google Service Account JSON key file
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
# The Google Drive folder ID to monitor
# (Get from URL: https://drive.google.com/drive/folders/THIS_IS_THE_ID)
GOOGLE_DRIVE_FOLDER_ID=your_folder_id_here

# === Scheduler ===
# Time to send daily summary (HH:MM format, 24h)
DAILY_REMINDER_TIME=07:00
# Time to send evening summary (HH:MM format, 24h)
EVENING_REMINDER_TIME=21:00
# How many days before deadline to start reminding
REMIND_BEFORE_DAYS=3
# How often to sync with Google Drive (in minutes)
SYNC_INTERVAL_MINUTES=30

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/teacher_bot.db

# === General ===
TIMEZONE=Asia/Ho_Chi_Minh
LOG_LEVEL=INFO
